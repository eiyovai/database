FROM mcr.microsoft.com/mssql/server:2022-latest

# 安装 dos2unix 处理换行符
USER root
RUN apt-get update && apt-get install -y dos2unix && rm -rf /var/lib/apt/lists/*

# 复制初始化脚本（使用完整的数据库备份脚本）
COPY database/00-full-backup.sql /init.sql
COPY docker/init-sqlserver.sh /init-sqlserver.sh
RUN dos2unix /init-sqlserver.sh && chmod +x /init-sqlserver.sh

USER mssql

CMD /bin/bash /init-sqlserver.sh
